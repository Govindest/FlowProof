# Local defaults. Railway overrides DATABASE_URL and FLOWPROOF_ARTIFACT_DIR.
DATABASE_URL=file:./dev.db
FLOWPROOF_ARTIFACT_DIR=artifacts
DEMO_BASE_URL=http://127.0.0.1:3100
NEXT_PUBLIC_FLOWPROOF_API_URL=http://127.0.0.1:3200
FLOWPROOF_PUBLIC_BASE_URL=http://127.0.0.1:3200
FLOWPROOF_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FLOWPROOF_BACKEND_SHARED_SECRET=flowproof-local-demo-secret

# GPT-5.6. Keep seeded for deterministic judging; use live with an API key.
FLOWPROOF_LLM_MODE=seeded
FLOWPROOF_LLM_MODEL=gpt-5.6
OPENAI_API_KEY=

# Backward-compatible aliases (optional): FLOWPROOF_MOCK, OPENAI_MODEL.
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repository
